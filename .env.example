# Expo public environment variables — copy to .env and fill in your values.
# These are bundled into the client app (prefix EXPO_PUBLIC_ is required).

# Google OAuth client IDs (from Google Cloud Console → APIs & Services → Credentials)
# Create an OAuth 2.0 Client ID for each platform you support.
# iOS: Application type = iOS, use the bundle ID from app.json (com.thrive.finance)
# Android: Application type = Android, use the package name from app.json
# Web: Application type = Web application
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Firebase config (from Firebase Console → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
