# Non-sensitive config — copy to .env and fill in
# These are read directly from process.env (not Secret Manager)
PLAID_ENV=production
PLAID_REDIRECT_URI=https://fortifyai.web.app/plaid/callback

# Sensitive secrets — set via Firebase Secret Manager:
#   firebase functions:secrets:set OPENAI_API_KEY
#   firebase functions:secrets:set PLAID_CLIENT_ID
#   firebase functions:secrets:set PLAID_SECRET
#   firebase functions:secrets:set ENCRYPTION_KEY      (32-byte hex = 64 chars)
#   firebase functions:secrets:set REVENUECAT_WEBHOOK_SECRET
