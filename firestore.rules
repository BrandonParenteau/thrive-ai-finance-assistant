rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own document and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /accounts/{accountId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /transactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // plaid_items written by Cloud Functions (admin SDK); owner can read
      match /plaid_items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Cloud Functions only (admin SDK bypasses rules)
      }
    }

    // plaid_sessions: Cloud Functions only — no client access
    match /plaid_sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
